[Unit]
Description=Claver VPS Agent
Documentation=https://github.com/rockclaver/claver
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=claver
Group=claver
ExecStart=/usr/local/bin/claver-agent --addr 127.0.0.1:7676
Restart=on-failure
RestartSec=2s

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
# The agent's *listener* is locked to loopback by an in-process self-check
# (assertLoopback). It still needs outbound network to clone repos, talk to
# GitHub (Device Flow, Phase 6), etc., so we leave egress open here.
ReadWritePaths=/var/lib/claver /etc/caddy/claver

[Install]
WantedBy=multi-user.target
